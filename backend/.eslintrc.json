{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "no-eval": "error",
    "no-implied-eval": "error",
    "eqeqeq": ["error", "smart"],
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_|next" }],
    "no-var": "warn",
    "prefer-const": "warn"
  }
}
