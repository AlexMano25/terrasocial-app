# ── TERRASOCIAL Backend Environment Variables ──
# Copy this file to backend/.env and fill in real values.
# NEVER commit .env files to git.

PORT=4000

# JWT Secret — MUST be at least 256 bits of randomness.
# Generate with: openssl rand -hex 32
JWT_SECRET=changeme_run_openssl_rand_hex_32

# Allowed CORS origins (comma-separated). REQUIRED in production.
CORS_ORIGIN=http://localhost:3000,http://localhost:5500

# Database — PostgreSQL connection string
DB_CLIENT=postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=changeme
SUPABASE_STORAGE_BUCKET=documents

# PostgreSQL SSL
PG_SSL=enable

# SMTP (email)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=changeme
SMTP_PASS=changeme
SMTP_FROM=noreply@manoverde.cm
SMTP_REPLY_TO=infos@manoverde.cm

# Google OAuth
GOOGLE_CLIENT_ID=changeme
GOOGLE_CLIENT_SECRET=changeme

# CamPay payment gateway
CAMPAY_API_KEY=changeme
CAMPAY_API_SECRET=changeme

# App URL (for emails, redirects)
APP_URL=https://social.manoverde.com
